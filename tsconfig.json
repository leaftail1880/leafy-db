{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"target": "ES2022",
		"moduleResolution": "nodenext",
		"module": "nodenext",
		"lib": ["ES2022"],
		"declaration": true,
		"emitDeclarationOnly": true,
		"noImplicitAny": true,
		"outDir": "types",
		"rootDir": "src/",
		"declarationMap": true,
		"allowSyntheticDefaultImports": true,
		"types": ["node"]
	},
	"exclude": ["./types/**", "./src/api/codes.js"],
	"include": ["./src/index.js"]
}
